#pragma once

// ============================================================
//  ACHAS -- SECRETS TEMPLATE  (this file IS committed)
// ============================================================
//  Copy to `src/secrets.h` and fill in real values.
//  `src/secrets.h` is in .gitignore so real secrets never leak.
//
//  PUBLIC material (Amazon Root CA, OTA signing public key) lives in
//  certs.h instead -- it is safe to commit.


// ---- AWS IoT Core endpoint (mutual-TLS MQTT, port 8883) ----
// AWS console: IoT Core -> Settings -> Device data endpoint.
#define AWS_IOT_ENDPOINT   "xxxxxxxx-ats.iot.ap-southeast-1.amazonaws.com"
#define AWS_IOT_PORT       8883


// ---- This device's AWS IoT certificate + private key ----
// (static arrays, NOT #define -- multi-line strings can't be in a #define)
static const char AWS_DEVICE_CERT[] = R"EOF(
-----BEGIN CERTIFICATE-----
PASTE_DEVICE_CERTIFICATE_HERE
-----END CERTIFICATE-----
)EOF";

static const char AWS_DEVICE_PRIVATE_KEY[] = R"EOF(
-----BEGIN RSA PRIVATE KEY-----
PASTE_DEVICE_PRIVATE_KEY_HERE
-----END RSA PRIVATE KEY-----
)EOF";


// ---- Self-OTA: HTTPS URL of the unified firmware file ----
#define OTA_SERVER_URL     "https://vps.example.com/firmware/firmware.bin"


// ---- Default WiFi credentials (used until commissioned) ----
#define DEFAULT_WIFI_SSID      "CHANGE_THIS_SSID"
#define DEFAULT_WIFI_PASSWORD  "CHANGE_THIS_PASSWORD"
